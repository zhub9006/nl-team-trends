# NL Team Trends — Starter EDA Notebook
# Exploratory Data Analysis of National League Season-by-Season Standings

```python
# ============================================================
# 01_eda_nl_standings.ipynb
# NL Team Trends - Exploratory Data Analysis
# ============================================================

import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import numpy as np
from scipy import stats

plt.style.use('seaborn-v0_8-whitegrid')
sns.set_palette('husl')

# ---------- Load Data ----------
df = pd.read_csv('data/nl_historical_performance.csv')
print(f"Dataset shape: {df.shape}")
print(f"\nColumns: {list(df.columns)}")
print(f"\nFirst 5 rows:")
df.head()

# ---------- Data Quality Check ----------
print(f"\nNull counts:")
print(df.isnull().sum())
print(f"\nData types:")
print(df.dtypes)

# ---------- Era Distribution ----------
print(f"\nEras and season counts:")
print(df['Era'].value_counts())

# ---------- NL Champions by Era ----------
champs = df.groupby('Era')['NL_Champion'].first()
print(f"\nNL Champions by Era (first entry):")
for era, team in champs.items():
    print(f"  {era}: {team}")

# ---------- Win Percentage Distribution ----------
fig, axes = plt.subplots(1, 2, figsize=(14, 5))

# Histogram of champion W-L%
axes[0].hist(df['Champion_WPct'].dropna(), bins=30, color='steelblue', edgecolor='white')
axes[0].set_title('Distribution of NL Champion W-L% (1876–2025)', fontsize=13)
axes[0].set_xlabel('Winning Percentage')
axes[0].set_ylabel('Frequency')
axes[0].axvline(df['Champion_WPct'].mean(), color='red', linestyle='--', label=f"Mean: {df['Champion_WPct'].mean():.3f}")
axes[0].legend()

# Box plot by era
champs_by_era = df.groupby('Era')['Champion_WPct'].apply(lambda x: x.dropna())
box_data = [champs_by_era.loc[era].values for era in champs_by_era.index]
axes[1].boxplot(box_data, labels=champs_by_era.index, patch_artist=True)
axes[1].set_title('NL Champion W-L% Distribution by Era', fontsize=13)
axes[1].set_xlabel('Era')
axes[1].set_ylabel('Winning Percentage')
axes[1].tick_params(axis='x', rotation=45)

plt.tight_layout()
plt.savefig('../visualizations/wl_pct_by_era.png', dpi=150, bbox_inches='tight')
plt.show()

# ---------- Top 10 Best Championship Seasons ----------
top10 = df.nlargest(10, 'Champion_WPct')[['Year', 'NL_Champion', 'Champion_Wins', 'Champion_Losses', 'Champion_WPct', 'Era']]
print("\nTop 10 Best NL Championship Seasons (by W-L%):")
print(top10.to_string(index=False))

# ---------- WS Results Summary ----------
ws_results = df['WS_Champion'].value_counts()
print(f"\nWS Champion Distribution:")
print(ws_results.head(10))

# ---------- Key Records ----------
print("\n=== KEY RECORDS ===")
best_wl = df.loc[df['Champion_WPct'].idxmax()]
print(f"Best W-L%: {best_wl['NL_Champion']} {int(best_wl['Champion_Wins'])}-{int(best_wl['Champion_Losses'])} (.{int(best_wl['Champion_WPct']*1000):03d}) in {int(best_wl['Year'])}")

champions_with_ws = df[df['WS_Champion'].notna() & (df['WS_Champion'] != 'None') & (df['WS_Result'] != 'NL lost WS')]
print(f"\nNL teams that won WS: {len(champions_with_ws)} out of {len(df)} seasons")

# ---------- Champion Win-Loss Trend Over Time ----------
fig, ax = plt.subplots(figsize=(14, 6))
valid = df.dropna(subset=['Champion_WPct'])
ax.plot(valid['Year'], valid['Champion_WPct'], marker='o', markersize=3, linewidth=1, color='steelblue', alpha=0.7)

# Add smoothed trend line
x = valid['Year'].values
y = valid['Champion_WPct'].values
mask = ~np.isnan(y)
slope, intercept, r_value, p_value, std_err = stats.linregress(x[mask], y[mask])
ax.plot(x[mask], intercept + slope*x[mask], 'r--', alpha=0.5, linewidth=2, label=f'Trend (slope={slope:.4f}/yr, r={r_value:.3f})')

ax.set_title('NL Champion Winning Percentage Over Time', fontsize=14)
ax.set_xlabel('Year')
ax.set_ylabel('Champion W-L%')
ax.legend()
plt.tight_layout()
plt.savefig('../visualizations/wl_trend_over_time.png', dpi=150, bbox_inches='tight')
plt.show()

print("\n\n=== ANALYSIS COMPLETE ===")
```

**Notes:**
- This notebook uses the complete `nl_historical_performance.csv` dataset
- Adjust era-specific W% benchmarks when comparing across schedule lengths
- The WS_Champion field uses 'None' for pre-WS era and 'NL lost WS' for seasons where the NL champion lost the World Series
- For more advanced H2H analysis, see `03_h2h_rivalries.ipynb`
